                  },
                  {
                    "text": "✏️ Edit",
                    "additionalFields": {
                      "callback_data": "edit"
                    }
                  },
                  {
                    "text": "❌ Reject",
                    "additionalFields": {
                      "callback_data": "reject"
                    }
                  }
                ]
              }
            }
          ]
        },
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
