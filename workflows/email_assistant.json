    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an email assistant. Classify the email into: inquiry, complaint, spam, newsletter, support, other. Write a professional draft reply in the same language. Respond ONLY with valid JSON: {\\\"category\\\": \\\"inquiry\\\", \\\"priority\\\": \\\"high|medium|low\\\", \\\"summary\\\": \\\"2-3 sentence summary\\\", \\\"draft_reply\\\": \\\"Full draft reply text\\\"}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ 'From: ' + ($json.headers.from || '') + '\\\\nSubject: ' + ($json.subject || '') + '\\\\nBody:\\\\n' + ($json.text || $json.snippet || '').replace(/\\\"/g, '\\\\\\\\\\\"').replace(/\\n/g, '\\\\\\\\n') }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "0ebec0b4-571d-4f0f-a0ca-67ea182e1b96",
      "name": "OpenAI Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        464,
        0
      ],
      "credentials": {
        "openAiApi": {
          "id": "sdsM773MEQKhCZ4J",
          "name": "OpenAI account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const source = $input.first().json;\nconst content = source.choices?.[0]?.message?.content || '{}';\nconst parsed = JSON.parse(content);\n\nreturn [\n  {\n    json: {\n      ...source,\n      ...parsed,\n      originalEmail: $('Gmail Trigger').first().json\n    }\n  }\n];"
      },
      "id": "eb22a571-0ced-470f-a325-d07e46961b47",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        0
      ]
    },
    {
      "parameters": {
        "chatId": "=8409896342",
        "text": "=📧 <b>New email</b>\n<b>From:</b> {{$json.originalEmail.from.value[0].name || $json.originalEmail.from.value[0].address}}\n<b>Subject:</b> {{$json.originalEmail.subject || $json.subject}}\n🏷 Category: {{$json.category}} | Priority: {{$json.priority}}\n📝 <b>Summary:</b>\n{{$json.summary}}\n✍️ <b>Draft reply:</b>\n{{$json.draft_reply}}",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "rows": [
            {
              "row": {
                "buttons": [
                  {
                    "text": "✅ Send",
                    "additionalFields": {
                      "callback_data": "=send:{{ $json.originalEmail.id }}"
